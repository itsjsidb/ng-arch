{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "schematics": {
    "@schematics/angular:component": {
      "name": "component",
      "type": "component",
      "changeDetection": "OnPush"
    },
    "@schematics/angular:service": {
      "addTypeToClassName": true,
      "name": "service",
      "type": "service",
      "path": "/src/app/core/services"
    },
    "@schematics/angular:guard": {
      "name": "guard",
      "typeSeparator": ".",
      "path": "/src/app/core/guards",
      "functional": true
    },
    "@schematics/angular:directive": {
      "name": "directive",
      "type": "directive",
      "addTypeToClassName": true,
      "path": "/src/app/shared/directives"
    },
    "@schematics/angular:pipe": {
      "name": "pipe",
      "typeSeparator": ".",
      "path": "/src/app/shared/pipes"
    },
    "@schematics/angular:interceptor": {
      "functional": true,
      "name": "interceptor",
      "typeSeparator": ".",
      "path": "/src/app/core/interceptors"
    },
    "@schematics/angular:resolver": {
      "name": "resolver",
      "typeSeparator": ".",
      "functional": true,
      "flat": true
    },
    "@schematics/angular:enum": {
      "name": "enum",
      "type": "enum"
    },
    "@schematics/angular:interface": {
      "name": "dto",
      "type": "dto"
    },
    "@schematics/angular:class": {
      "name": "model",
      "type": "model"
    },
    "@schematics/angular:web-worker": {
      "name": "worker"
    }
  },
  "cli": {
    "packageManager": "npm",
    "schematicCollections": ["angular-eslint"],
    "analytics": false
  },
  "newProjectRoot": "projects",
  "projects": {
    "ng-arch": {
      "projectType": "application",
      "schematics": {},
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "src/main.ts",
            "tsConfig": "tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "public"
              }
            ],
            "styles": ["src/styles.css"],
            "server": "src/main.server.ts",
            "outputMode": "server",
            "security": {
              "allowedHosts": []
            },
            "ssr": {
              "entry": "src/server.ts"
            }
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all",
              "serviceWorker": "ngsw-config.json"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "ng-arch:build:production"
            },
            "development": {
              "buildTarget": "ng-arch:build:development",
              "hmr": true,
              "host": "0.0.0.0",
              "allowedHosts": ["localhost", "127.0.0.1"]
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@analogjs/vitest-angular:test"
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": ["src/**/*.ts", "src/**/*.html"]
          }
        }
      }
    }
  }
}
